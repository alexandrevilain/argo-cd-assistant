{
  "name": "argo-cd-assistant",
  "version": "0.2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "@types/bun": "catalog:"
  },
  "catalog": {
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@ai-sdk/react": "^4.0.16",
    "ai": "^7.0.15",
    "@types/bun": "1.3.14"
  },
  "private": true,
  "scripts": {
    "dev:ext": "bun run --cwd apps/extension dev",
    "dev:backend": "bun run --cwd apps/backend dev",
    "build:ext": "bun run --cwd apps/extension build",
    "build:backend": "bun run --cwd apps/backend build",
    "test": "echo \"No tests for now\"",
    "lint": "bunx eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "bunx eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "typecheck": "bunx tsc --noEmit",
    "changeset": "bunx -y changeset",
    "version-packages": "bunx -y changeset version",
    "release": "bunx -y changeset publish"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "axios": "^1.18.1",
    "hono": "^4.12.27",
    "styled-components": "^6.4.3",
    "zod": "^4.4.3"
  }
}
